{
  "name": "semantic-recall",
  "version": "1.1.0",
  "description": "Persistent semantic memory for LLM apps, AI agents, and chatbots. Zero config, zero API keys, works fully offline. SQLite + local embeddings via Transformers.js. Two methods: remember() and recall(). Drop-in Mem0 alternative and LangChain memory alternative.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/storage/turso": {
      "import": {
        "types": "./dist/adapters/storage/turso.d.ts",
        "default": "./dist/adapters/storage/turso.js"
      },
      "require": {
        "types": "./dist/adapters/storage/turso.d.cts",
        "default": "./dist/adapters/storage/turso.cjs"
      }
    },
    "./adapters/storage/supabase": {
      "import": {
        "types": "./dist/adapters/storage/supabase.d.ts",
        "default": "./dist/adapters/storage/supabase.js"
      },
      "require": {
        "types": "./dist/adapters/storage/supabase.d.cts",
        "default": "./dist/adapters/storage/supabase.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "keywords": [
    "memory",
    "semantic-recall",
    "semantic-memory",
    "llm",
    "llm-memory",
    "ai",
    "ai-memory",
    "ai-agent",
    "agent-memory",
    "chatbot",
    "chatbot-memory",
    "embedding",
    "vector",
    "vector-search",
    "sqlite",
    "persistent-memory",
    "rag",
    "retrieval-augmented-generation",
    "conversational-ai",
    "transformers",
    "local-embeddings",
    "offline-embedding",
    "zero-config",
    "context-window",
    "mcp",
    "model-context-protocol",
    "cursor-ai",
    "openai-memory",
    "langchain-alternative",
    "mem0-alternative",
    "semantic-search"
  ],
  "author": "skt329",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skt329/semantic-recall"
  },
  "homepage": "https://github.com/skt329/semantic-recall#readme",
  "bugs": {
    "url": "https://github.com/skt329/semantic-recall/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.4.0",
    "better-sqlite3": "^11.7.0",
    "@libsql/client": "^0.14.0",
    "@supabase/supabase-js": "^2.49.0",
    "openai": "^4.90.0"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.7.0",
    "@huggingface/transformers": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": { "optional": true },
    "@huggingface/transformers": { "optional": true }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
