{
  "name": "semantic-recall",
  "version": "1.0.0",
  "description": "Drop-in persistent semantic memory for LLM apps. Zero config, zero API keys. Two methods: remember() and recall().",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "keywords": [
    "memory",
    "semantic-recall",
    "llm",
    "ai",
    "chatbot",
    "embedding",
    "vector",
    "sqlite",
    "persistent-memory",
    "rag",
    "conversational-ai",
    "transformers"
  ],
  "author": "skt329",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skt329/semantic-recall"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "better-sqlite3": "^11.7.0"
  },
  "optionalDependencies": {
    "@libsql/client": "^0.14.0",
    "@supabase/supabase-js": "^2.49.0",
    "openai": "^4.90.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
